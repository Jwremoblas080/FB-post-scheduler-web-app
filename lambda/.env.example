# Copy to .env and fill in values before deploying

FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret

# Set this to your API Gateway URL after first deploy
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com/auth/callback
FACEBOOK_REDIRECT_URI=https://YOUR_API_GATEWAY_URL/auth/callback

ENCRYPTION_KEY=generate_32_char_random_string
ENCRYPTION_SECRET=generate_32_char_random_string

# Your frontend URL (Vercel, Netlify, etc.)
FRONTEND_URL=https://your-frontend.vercel.app

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app
